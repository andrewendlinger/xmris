# ==============================================================================
# 1. Environment & Package Management (uv / pip)
# ==============================================================================
# Python virtual environments
.venv/
venv/
env/
.env/

# Note: We commit pyproject.toml and uv.lock to ensure reproducible builds.
# If you are developing a library and strictly don't want the lock file, uncomment below:
# uv.lock

# ==============================================================================
# 2. Python Core & Build Artifacts
# ==============================================================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / Packaging
build/
dist/
sdist/
wheels/
*.egg-info/
.eggs/
*.egg
lib/
lib64/
parts/
var/
eggs/
.installed.cfg
downloads/

# ==============================================================================
# 3. Code Quality & Testing (Ruff, MyPy, Pytest)
# ==============================================================================
# Testing and coverage
.pytest_cache/
.tox/
.nox/
.coverage
.coverage.*
coverage.xml
*.cover
htmlcov/

# Linters and Type Checkers
.ruff_cache/
.mypy_cache/
.cache/

# ==============================================================================
# 4. Documentation (MyST / Jupyter Book / Sphinx)
# ==============================================================================
# Generated build artifacts
_build/
docs/_build/

# Generated API reference files (if auto-generated)
docs/api_reference/
docs/objects.json

# MyST execution cache (results of code blocks)
.myst/
docs/.jupyter_cache/
*.jupyter_cache/
_timestamp

# ==============================================================================
# 5. Jupyter & Jupytext
# ==============================================================================
# Ignore Jupyter internal checkpoints
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# IPython configuration
profile_default/
ipython_config.py

# JUPYTEXT WORKFLOW:
# Ignore binary .ipynb files in the docs folder (Markdown/Script is the source).
# If you want to commit selected notebooks, use `git add -f`.
docs/**/*.ipynb
docs/**/**/*.ipynb
docs/**/**/**/*.ipynb
# ==============================================================================
# 6. IDEs & Operating System
# ==============================================================================
# VS Code
.vscode/

# JetBrains / PyCharm
.idea/

# Editor temporary files
*.swp
*.swo
*~

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ==============================================================================
# 7. Scientific Data (MRI / MRS / NIfTI)
# ==============================================================================
# CRITICAL: Prevent committing large datasets or raw medical images.
# These extensions should never be tracked by git.
*.dat
*.rda
*.h5
*.h5ad
*.nc
*.nii
*.nii.gz
*.fid
*.raw
*.ima
*.dcm

# ==============================================================================
# 8. Test Data Exceptions
# ==============================================================================
# Strategy: Ignore all data in tests/data, then whitelist specific small files.

# 1. Ignore everything inside tests/data recursively
tests/data/**

# 2. Re-include specific subdirectories (required for git to look inside them)
!tests/data/nspect_slab_1H/
!tests/data/nspect_slab_13C/

# 3. Re-include ONLY specific ground truth and raw files (<10MB)
!tests/data/nspect_slab_1H/ground_truth.toml
!tests/data/nspect_slab_1H/rawdatajob0.nc
!tests/data/nspect_slab_13C/ground_truth.toml
!tests/data/nspect_slab_13C/rawdatajob0.nc